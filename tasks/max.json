{
    "name": "max",
    "description": "Maximum of two signed inputs",
    "max_cycles": 100,
    "input_ports": [0, 1],
    "output_ports": [0],
    "tests": [
        {"in": [3, 5],         "out": [5]},
        {"in": [5, 3],         "out": [5]},
        {"in": [0, 0],         "out": [0]},
        {"in": [65535, 1],     "out": [1]},
        {"in": [100, 200],     "out": [200]},
        {"in": [32767, 0],     "out": [32767]},
        {"in": [32769, 32767], "out": [32767]},
        {"in": [65535, 65534], "out": [65535]}
    ]
}
