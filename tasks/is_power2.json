{
    "name": "is_power2",
    "description": "Output 1 if input is a power of 2, 0 otherwise (0 is not a power of 2)",
    "max_cycles": 100,
    "input_ports": [0],
    "output_ports": [0],
    "tests": [
        {"in": [1],     "out": [1]},
        {"in": [2],     "out": [1]},
        {"in": [3],     "out": [0]},
        {"in": [4],     "out": [1]},
        {"in": [5],     "out": [0]},
        {"in": [8],     "out": [1]},
        {"in": [16],    "out": [1]},
        {"in": [0],     "out": [0]},
        {"in": [255],   "out": [0]},
        {"in": [256],   "out": [1]},
        {"in": [32768], "out": [1]}
    ]
}
