{
    "name": "gcd",
    "description": "Greatest common divisor of two inputs (Euclidean algorithm)",
    "max_cycles": 5000,
    "input_ports": [0, 1],
    "output_ports": [0],
    "tests": [
        {"in": [12, 8],   "out": [4]},
        {"in": [15, 10],  "out": [5]},
        {"in": [7, 3],    "out": [1]},
        {"in": [100, 75], "out": [25]},
        {"in": [1, 1],    "out": [1]},
        {"in": [48, 18],  "out": [6]},
        {"in": [17, 13],  "out": [1]},
        {"in": [36, 24],  "out": [12]},
        {"in": [1000, 400], "out": [200]}
    ]
}
